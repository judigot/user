# OpenCode / MCP shared environment variables
# Copy to: ~/.devrc.d/.env
# Then load it from ~/.bashrc or ~/.zshrc:
#   [ -f "$HOME/.devrc.d/.env" ] && set -a && . "$HOME/.devrc.d/.env" && set +a

# Backlog MCP
BACKLOG_DOMAIN=seed-tech.backlog.com
BACKLOG_API_KEY=replace_with_backlog_api_key

# Context7 MCP
CONTEXT7_API_KEY=replace_with_context7_api_key

# Figma MCP
FIGMA_API_KEY=replace_with_figma_api_key
